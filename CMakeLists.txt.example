cmake_minimum_required(VERSION 3.12)

# include(cmake/arm-gcc.6.2.inc)

set(ARM_MCU "samd20j18")

project(MyProject C CXX ASM)

set(target_name ${PROJECT_NAME})

set(elf_file ${target_name}-${ARM_MCU}.elf)
set(map_file ${target_name}-${ARM_MCU}.map)
set(hex_file ${target_name}-${ARM_MCU}.hex)
set(lst_file ${target_name}-${ARM_MCU}.lst)

# create elf file
add_executable(
    ${elf_file}

    Emerald.cpp
)

set_target_properties(
    ${elf_file}

    PROPERTIES

        C_STANDARD   11
        C_STANDARD_REQUIRED TRUE
        C_EXTENSIONS FALSE

        CXX_STANDARD 11
        CXX_STANDARD_REQUIRED TRUE
        CXX_EXTENSIONS FALSE

        INTERPROCEDURAL_OPTIMIZATION FALSE      # This disables LTO, (Which is default off)

	LINK_FLAGS "-mcpu=cortex-m0plus -mthumb -mtune=cortex-m0plus -Os -T${CMAKE_SOURCE_DIR}/cmsis/linkerScripts/samd20j18_flash.ld -Wl,--gc-sections -Wl,-Map=${map_file} -Xlinker --defsym=STACK_SIZE=0x1000"
)

