# set definitions
add_definitions(
    -D__SAMD20J18__
    -DADC_CALLBACK_MODE=false
    -DARM_MATH_CM0=true
    -DBOARD=USER_BOARD
    -DDAC_CALLBACK_MODE=false
    -DDEBUG
    -DEMERALDCONNECTED
    -DEXTINT_CALLBACK_MODE=true
    -DI2C_MASTER_CALLBACK_MODE=false
    -DRTC_COUNT_ASYNC=false
    -DSYSTICK_MODE
    -DTC_ASYNC=true
    -DUSART_CALLBACK_MODE=true
    -DWDT_CALLBACK_MODE=false
)

add_subdirectory(./../shared/libraries/EmbeddedRPC_Topaz EmbeddedRPC_Topaz)
add_subdirectory(./BootAssistantMonitor)

# Set compiler flags and options
target_compile_options(
    ${elf_file}

	PRIVATE
		${COMPILER_FLAGS}
)

