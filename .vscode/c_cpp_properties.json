{
    "configurations": [
        {
            "name": "Debug",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "__CORTEX_M=0x03",
                "__GNUC__",
                "STM32F103xB",
                "USE_FULL_LL_DRIVER"
            ],
            "cStandard": "${default}",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",
            "configurationProvider": "ms-vscode.cmake-tools",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "compilerPath": "${workspaceFolder}/../gcc-arm-none-eabi-9-2019-q4-major-win32/bin/arm-none-eabi-g++.exe"
        }
    ],
    "version": 4
}