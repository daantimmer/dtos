{
    "configurations": [
        {
            "name": "Debug",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/libs/hal",
                "${workspaceFolder}/libs/hal_stm32f103",
                "${workspaceFolder}/libs/hal_stm32f103/target/arm/stm32f1/CMSIS/Device/ST/STM32F1xx/Include",
                "${workspaceFolder}/libs/hal_stm32f103/target/arm/stm32f1/inc",
                "${workspaceFolder}/libs/hal_stm32f103/target/arm/stm32f1/CMSIS/Device/ST/STM32F1xx/Include",
                "${workspaceFolder}/libs/hal_stm32f103/target/arm/stm32f1/CMSIS/Include"
            ],
            "defines": [
                "__CORTEX_M=0x03",
                "__GNUC__",
                "STM32F103xB",
                "USE_FULL_LL_DRIVER"
            ],
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "configurationProvider": "ms-vscode.cmake-tools",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "compilerPath": "${workspaceFolder}/../gcc-arm-none-eabi-9-2019-q4-major-win32/bin/arm-none-eabi-g++.exe"
        }
    ],
    "version": 4
}